{
  "name": "gleider-dev",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "pnpm --filter @gleider-dev/api db:migrate",
    "db:seed": "pnpm --filter @gleider-dev/api db:seed",
    "db:reset": "pnpm --filter @gleider-dev/api db:reset",
    "db:studio": "pnpm --filter @gleider-dev/api db:studio",
    "docker:up": "docker compose up -d",
    "docker:rebuild": "docker compose up -d --build",
    "docker:rebuild:web": "docker compose up -d --build web",
    "docker:rebuild:api": "docker compose up -d --build api",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  }
}
